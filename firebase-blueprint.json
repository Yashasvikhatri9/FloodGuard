{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID" },
        "email": { "type": "string", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User photo URL" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["uid", "email", "role"]
    },
    "Ward": {
      "title": "Ward Data",
      "description": "Active ward monitoring data",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Ward ID" },
        "name": { "type": "string", "description": "Ward name" },
        "risk": { "type": "string", "enum": ["High", "Medium", "Safe"], "description": "Risk level" },
        "level": { "type": "number", "description": "Flood probability level (%)" },
        "lat": { "type": "number", "description": "Latitude" },
        "lng": { "type": "number", "description": "Longitude" },
        "color": { "type": "string", "description": "Color code for map" },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["id", "name", "risk", "level", "lat", "lng"]
    },
    "FloodReport": {
      "title": "Flood Report",
      "description": "User submitted flood report",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Report ID" },
        "reporterName": { "type": "string", "description": "Reporter name" },
        "reporterUid": { "type": "string", "description": "Reporter UID" },
        "location": { "type": "string", "description": "Location description" },
        "lat": { "type": "number", "description": "Latitude" },
        "lng": { "type": "number", "description": "Longitude" },
        "level": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"], "description": "Flood level" },
        "description": { "type": "string", "description": "Detailed description" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Report timestamp" },
        "status": { "type": "string", "enum": ["pending", "verified", "resolved"], "description": "Report status" }
      },
      "required": ["reporterName", "location", "level", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/wards/{wardId}": {
      "schema": "Ward",
      "description": "Active ward monitoring data"
    },
    "/reports/{reportId}": {
      "schema": "FloodReport",
      "description": "User flood reports"
    }
  }
}
